			status = "disabled";
		};
	};

	fragment@10 {
		target-path = "/mipi-csi2-hw@ffa20000";
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@11 {
		target-path = "/mipi-csi2-hw@ffa30000";
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@12 {
		target-path = "/rkisp-vir0";
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@13 {
		target-path = "/i2c@ff470000/sc3336@30";
