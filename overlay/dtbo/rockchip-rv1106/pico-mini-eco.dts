		};
	};

	fragment@17 {
		target-path = "/mpp-vcodec";
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@18 {
		target-path = "/rkvenc@ffa50000";
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@19 {
		target-path = "/rkvenc-pp@ffa60000";
		__overlay__ {
			status = "disabled";
		};
	};

	fragment@20 {
